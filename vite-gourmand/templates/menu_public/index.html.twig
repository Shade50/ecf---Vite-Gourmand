{% extends 'base.html.twig' %}

{% block title %}Nos menus - Vite & Gourmand
{% endblock %}

{% block body %}
	<div class="container py-5">
		<h1 class="mb-4">🍽️ Nos menus</h1>

		<div class="card shadow-sm mb-4">
			<div class="card-body">

				<div class="row g-3">

					<div class="col-md-2">
						<label class="form-label">Prix min</label>

						<input type="number" id="priceMin" class="form-control">
					</div>

					<div class="col-md-2">
						<label class="form-label">Prix max</label>

						<input type="number" id="priceMax" class="form-control">
					</div>

					<div class="col-md-3">

						<label class="form-label">
							Thème
						</label>

						<select id="theme" class="form-select">

							<option value="">
								Tous
							</option>

							{% for theme in themes %}

								<option value="{{ theme.id }}">
									{{ theme.label }}
								</option>

							{% endfor %}

						</select>

					</div>

					<div class="col-md-3">

						<label class="form-label">

							Régime

						</label>

						<select id="regime" class="form-select">

							<option value="">
								Tous
							</option>

							{% for regime in regimes %}

								<option value="{{ regime }}">
									{{ regime }}
								</option>

							{% endfor %}

						</select>

					</div>

					<div class="col-md-2">

						<label class="form-label">

							Personnes

						</label>

						<input type="number" id="numberOfPeople" min="1" class="form-control">

					</div>

				</div>

			</div>

		</div>

		<div id="menus-container">

			{% include 'menu_public/_menu_cards.html.twig' %}

		</div>
	</div>
	{% block javascripts %}
		{{ parent() }}
		<script src="{{ asset('js/menu-filter.js') }}"></script>
	{% endblock %}
{% endblock %}
