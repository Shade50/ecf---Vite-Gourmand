{% extends 'base.html.twig' %}

{% block title %}Nos menus - Vite & Gourmand{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4">🍽️ Nos menus</h1>

    <div class="row">
        {% for menu in menus %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h2 class="h4">{{ menu.title }}</h2>

                        <p>{{ menu.description }}</p>

                        <p>
    <strong>{{ menu.price }} €</strong>
    <br>
    Minimum : {{ menu.minimumPerson }} personnes
</p>

{% if menu.stock > 0 %}
    <p class="text-success">
        Stock disponible : {{ menu.stock }} commande(s)
    </p>

    <a href="{{ path('app_order_create', { id: menu.id }) }}"
       class="btn btn-primary">
        Commander
    </a>
{% else %}
    <p class="text-danger fw-bold">
        Rupture de stock
    </p>

    <button class="btn btn-secondary" disabled>
        Commander
    </button>
{% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <p>Aucun menu disponible actuellement.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}