{% extends 'base.html.twig' %}

{% block title %}Nos menus - Vite & Gourmand{% endblock %}

{% block body %}
<div class="container py-5">
    <h1 class="mb-4">🍽️ Nos menus</h1>

    <div class="row">
        {% for menu in menus %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h2 class="h4">{{ menu.title }}</h2>

                        <p>{{ menu.description }}</p>

                        <p>
                            <strong>{{ menu.price }} €</strong>
                            <br>
                            Minimum : {{ menu.minimumPerson }} personnes
                        </p>

                        <a href="{{ path('app_order_create', { id: menu.id }) }}"
                           class="btn btn-primary">
                            Commander
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <p>Aucun menu disponible actuellement.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}