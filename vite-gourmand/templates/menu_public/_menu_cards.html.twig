<div class="row">
    {% for menu in menus %}
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">

                <div class="card-body">

                    <h2 class="h4">
                        {{ menu.title }}
                    </h2>

                    <p>{{ menu.description }}</p>

                    <p>
                        <strong>{{ menu.price }} €</strong>
                        <br>
                        Minimum : {{ menu.minimumPerson }} personnes
                    </p>

                    <p>
                        <strong>Thème :</strong>
                        {{ menu.theme.label }}
                    </p>

                    {% if menu.stock > 0 %}

                        <p class="text-success">
                            Stock disponible :
                            {{ menu.stock }}
                            commande(s)
                        </p>

                        <a
                            href="{{ path('app_menu_public_show', {id: menu.id}) }}"
                            class="btn btn_admin_setting">

                            Voir le détail

                        </a>

                        <a
                            href="{{ path('app_order_create', {id: menu.id}) }}"
                            class="btn btn_admin_setting">

                            Commander

                        </a>

                    {% else %}

                        <p class="text-danger fw-bold">

                            Rupture de stock

                        </p>

                        <button
                            class="btn btn-secondary"
                            disabled>

                            Commander

                        </button>

                    {% endif %}

                </div>

            </div>
        </div>

    {% else %}

        <div class="col-12">

            <div class="alert alert-warning">

                Aucun menu ne correspond aux filtres.

            </div>

        </div>

    {% endfor %}
</div>