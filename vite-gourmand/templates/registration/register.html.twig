{% extends 'base.html.twig' %}

{% block title %}Register
{% endblock %}

{% block body %}

	{# <div class="container">
											<div class="row justify-content-center"> #}
	<div class="container mt-5">
		<div class="row g-4 {% if not is_granted('ROLE_ADMIN') %}justify-content-center{% endif %}">
			<div class="col-lg-5 d-flex">
				<div class="card p-3 mb-5 text-center w-100 h-auto">
					<h1>Créer un compte</h1>

					{{ form_errors(registrationForm) }}

					{{ form_start(registrationForm) }}
					{{ form_row(registrationForm.nom) }}
					{{ form_row(registrationForm.prenom) }}
					{{ form_row(registrationForm.adressePostale) }}
					{{ form_row(registrationForm.email) }}

					{{ form_row(registrationForm.plainPassword, {label: 'Password'}) }}

					{{ form_row(registrationForm.gsm) }}
					{% if registrationForm.agreeTerms is defined %}
						{{ form_row(registrationForm.agreeTerms) }}
					{% endif %}
					{% if registrationForm.createAsEmployee is defined %}
						{{ form_row(registrationForm.createAsEmployee) }}
					{% endif %}


					<div class="mt-3 mb-2 d-flex justify-content-center gap-3">
						<button type="submit" class="btn btn_admin_setting mr-5">Créer mon compte</button>
						{% if is_granted('ROLE_ADMIN') %}
							<a href="{{ path('app_admin') }}" class="btn btn_admin_setting mr-5">
								Retour
							</a>
						{% else %}
							<a href="{{ path('app_login') }}" class="btn btn_admin_setting mr-5">
								Retour
							</a>
						{% endif %}
					</div>


					{{ form_end(registrationForm) }}
				</div>
			</div>
			{% if is_granted('ROLE_ADMIN') %}
				<div class="col-lg-7 d-flex">
					<div
						class="card p-3 mb-5 text-center w-100 h-auto">
						{# <div class="card shadow-sm w-100 h-auto"> #}


						<div class="card-header">

							<div class="col-lg-7">
								<h4 class="mb-0">
									Employés ({{ employees|length }})
								</h4>
							</div>

							<div class="card-body p-0">

								<table class="table table-hover mb-0 align-middle">

									<thead>
										<tr>
											<th>Nom</th>
											<th>Email</th>
											<th>Télèphone</th>
											<th>Statut</th>
											<th class="text-end">Action</th>
										</tr>
									</thead>

									<tbody>

										{% for employee in employees %}

											<tr>

												<td>
													{{ employee.prenom }}
													{{ employee.nom }}
												</td>

												<td>
													{{ employee.email }}
												</td>

												<td>
													{{ employee.gsm }}
												</td>

												<td>

													{% if employee.isActive %}

														<span class="badge bg-success">
															Actif
														</span>

													{% else %}

														<span class="badge bg-danger">
															Inactif
														</span>

													{% endif %}

												</td>

												<td class="text-end">

													<form method="post" action="{{ path('app_admin_employee_toggle', {id: employee.id}) }}" onsubmit="return confirm(
																																													        '{{ employee.isActive
																																													            ? 'Désactiver ce compte employé ?'
																																													            : 'Réactiver ce compte employé ?'
																																													        }}'
																																													    );">
														<input type="hidden" name="_token" value="{{ csrf_token('toggle_employee_' ~ employee.id) }}">

														{% if employee.isActive %}
															<button type="submit" class="btn btn-sm btn-outline-danger">
																Désactiver
															</button>
														{% else %}
															<button type="submit" class="btn btn-sm btn-outline-success">
																Réactiver
															</button>
														{% endif %}
													</form>

												</td>

											</tr>

										{% else %}

											<tr>

												<td colspan="4" class="text-center">

													Aucun employé.

												</td>

											</tr>

										{% endfor %}

									</tbody>

								</table>

							</div>


						</div>
					</div>
				</div>
			{% endif %}

		</div>
	</div>
{% endblock %}
