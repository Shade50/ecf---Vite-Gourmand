
<div class="container mt-5 ">
    {# partie haute du component contact #}
	<div class="row">
        <div class="col-md-12 text-center justify-content-center">
		    <h1 class="mb-3">Contactez-nous</h1>
		    <p class="d-flex justify-content-center">
			    Une question ? Un devis ? Une commande de groupe ?
			</p>  
			<p>
                <span class="red-text">Nous somme à votre écoute !</span>
            </p>
		    
            <hr class="separator mx-auto">
            
        </div>
	</div>
    {# partie des cards du component contact #}
	<div class="row justify-content-center ">
        {# partie de la card Nos coordonnées du component contact #}
		<div class="col-md-5 form-contact">
			<h4 class="red-text"><i class="bi bi-person-vcard me-2"></i>Nos coordonnées</h4>
			<hr class="separator">
			<p>
				<i class="bi bi-phone me-2 red-text"></i>
				<span class="fw-bold">Téléphone :</span> 01 23 45 67 89
			</p>
			<p>
				<i class="bi bi-envelope me-2 red-text"></i>
				<span class="fw-bold">Email :</span> contact@viteetgourmand.fr
			</p>
			<p>
				<i class="bi bi-geo-alt me-2 red-text"></i>
				<span class="fw-bold">Adresse :</span> 123 Rue de la Paix, 33000 Bordeaux
			</p>
			<p>
				<i class="bi bi-clock me-2 red-text"></i>
				Nos horaires d'ouverture :

                <div class="horaires-contact">
                    <p>				 
				    <span class="fw-bold">Lundi au vendredi :</span></br>
                    08:00 - 12:00 et 13:00 - 19:00
				<br>
				    <span class="fw-bold">Samedi :</span> </br>
                    08:00 - 13:00
				<br>
				    <span class="fw-bold">Dimanche :</span> Fermé
                </p>
                </div>
                
			</p>

		</div>

		<div class="col-md-5 row justify-content-center form-contact">
            {# partie formulaire de la card Nos coordonnées du component contact #}
            <div>
			    <h4 class="red-text"><i class="bi bi-envelope me-2"></i>Envoyer-nous un message</h4>
                <hr class="separator">
            </div>
			<form action="{{ path('app_contact') }}" method="post">

				<div class="row ">
					<div class="mb-3 col-md-6">
						<input type="text" class="form-control" placeholder="Votre nom" id="name" name="name" required>
					</div>

					<div class="mb-3 col-md-6">
						<input type="email" class="form-control" placeholder="Votre email" id="email" name="email" required>
					</div>
				</div>

				<div class="mb-3">
					<input type="text" class="form-control" placeholder="Sujet de votre message" id="subject" name="subject" required>
				</div>

				<div class="mb-3">
					<textarea class="form-control" placeholder="Votre message" id="message" name="message" rows="4" required></textarea>
				</div>
				<div class="d-flex justify-content-center">
					<button type="submit" class="btn btn-color">Envoyer</button>
				</div>
			</form>

		</div>

	</div>

</div>
