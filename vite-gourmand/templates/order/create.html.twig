{% extends 'base.html.twig' %}

{% block title %}Commander {{ menu.title }}{% endblock %}

{% block body %}
{% for message in app.flashes('danger') %}
    <div class="alert alert-danger" role="alert">
        {{ message }}
    </div>
{% endfor %}
{# 
debut card mes infos #}

    <div class="mb-4">

        <h2 class="h4">Vos informations</h2>

        <p class="mb-1">
            <strong>Nom: </strong> {{app.user.nom}}
        </p>

        <p class="mb-1">
            <strong>Prénom: </strong> {{app.user.prenom}}
        </p>

        <p class="mb-1">
            <strong>Email: </strong> {{app.user.email}}
        </p>

        <p class="mb-1">
            <strong>Télèphone: </strong> {{app.user.gsm}}
        </p>

    </div>

{# fin de card mes infos #}

{# debut card ma commande #}
<p>
    Prix du menu :
    <strong>{{ menu.price }} €</strong>
    pour {{ menu.minimumPerson }} personnes minimum
</p>

<p>
    Total :
    <strong>
        <span id="total-price">{{ menu.price }}</span> €
    </strong>
</p>

<p id="discount-message" class="text-success d-none">
    Réduction de 10 % appliquée
</p>

{{ form_start(form) }}
    {{ form_row(form.deliveryDate) }}
    {{ form_row(form.numberOfPeople) }}
    {{ form_row(form.deliveryAdresse) }}

    <button type="submit" class="btn btn-primary">
        Valider la commande
    </button>
{{ form_end(form) }}

{# fin de la card mes commande #}
<script>
    const numberOfPeople = document.getElementById(
        '{{ form.numberOfPeople.vars.id }}'
    );

    const totalPrice = document.getElementById('total-price');
    const discountMessage = document.getElementById('discount-message');

    const menuPrice = parseFloat(
        {{ menu.price|json_encode|raw }}
    );

    const minimumPerson = {{ menu.minimumPerson }};

    function updateTotal() {
        const people = parseInt(numberOfPeople.value) || 0;

        if (people < minimumPerson) {
            totalPrice.textContent = menuPrice.toFixed(2);
            discountMessage.classList.add('d-none');
            return;
        }

        const pricePerPerson = menuPrice / minimumPerson;
        let total = pricePerPerson * people;

        if (people >= minimumPerson + 5) {
            total *= 0.90;
            discountMessage.classList.remove('d-none');
        } else {
            discountMessage.classList.add('d-none');
        }

        totalPrice.textContent = total.toFixed(2);
    }

    numberOfPeople.addEventListener('input', updateTotal);

    updateTotal();
</script>
{% endblock %}