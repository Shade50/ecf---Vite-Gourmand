{% extends 'base.html.twig' %}

{% block title %}Gestion du catalogue{% endblock %}

{% block body %}

<div class="container py-5">
    <h1 class="text-center mb-4">Gestion du catalogue</h1>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card p-4 h-80 ">

                <h2 class="text-center">Nouvelle allergène</h2>

                {{ form_start(allergeneForm) }}

                    <div class="container py-5">
                        <div class="col-md-12">

                            {{ form_row(allergeneForm.label) }}
                            {{ form_row(allergeneForm.description) }}
                            {{ form_row(allergeneForm.plats) }}
                
                            <div class="text-center">
                                <button class="btn btn_admin_setting btn_admin_menu">Enregistrer</button>
                                <a href="{{ path('app_allergene_index')}}" class="mt-1 btn btn_admin_setting btn_admin_menu">Voir la liste</a>
                            </div>
                        </div>
                    </div>
                {{ form_end(allergeneForm)}}

                

            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-4 h-100">

                <h2>Créer un thème</h2>

                {{ form_start(themeForm) }}

                    <div class="container py-5">
                        <div class="col-md-12">
                            {{ form_row(themeForm.label) }}
                            {{ form_row(themeForm.description) }}

                            <div class="text-center">
                                <button class="btn btn_admin_setting mt-3">Enregistrer</button>
                                </br>
                                <a href="{{ path('app_theme_index')}}" class="mt-3">Voir la liste</a>
                            </div>
                        </div>
                    </div>
                {{ form_end(themeForm)}}

                

            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-4 h-100">

                <h2>Créer un plat</h2>

                {{ form_start(platForm) }}
                    {{ form_widget(platForm) }}
                    <button class="btn btn_admin_setting mt-3">Enregistrer</button>
                {{ form_end(platForm)}}

                <a href="{{ path('app_plat_index')}}" class="mt-3">Voir la liste</a>

            </div>
        </div>

        <div class="col-md-6">
            <div class="card p-4 h-100">

                <h2>Créer un menu</h2>

                {{ form_start(menuForm) }}
                    {{ form_widget(menuForm) }}
                    <button class="btn btn_admin_setting mt-3">Enregistrer</button>
                {{ form_end(menuForm)}}

                <a href="{{ path('app_menu_index')}}" class="mt-3">Voir la liste</a>

            </div>
        </div>

    </div>

</div>

{% endblock %}
