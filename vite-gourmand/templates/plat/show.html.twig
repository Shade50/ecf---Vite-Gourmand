{% extends 'base.html.twig' %}

{% block title %}Plat{% endblock %}

{% block body %}
    <h1>Plat</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ plat.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ plat.title }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ plat.description }}</td>
            </tr>

            <tr>
                <th>Photo</th>
                <td>{{ plat.photo }}</td>
            </tr>

            <tr>
                <th>Type</th>
                <td>{{ plat.type }}</td>
            </tr>
            <tr>
                <th>Regime</th>
                <td>{{ plat.regime }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_plat_index') }}">back to list</a>

    <a href="{{ path('app_plat_edit', {'id': plat.id}) }}">edit</a>

    {{ include('plat/_delete_form.html.twig') }}
{% endblock %}
