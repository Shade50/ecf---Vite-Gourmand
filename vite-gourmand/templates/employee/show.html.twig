{% extends 'base.html.twig' %}

{% block title %}
	Commande n°{{ order.id }}
{% endblock %}

{% block body %}

	{% set statusClasses = {
    'En attente': 'text-bg-warning',
    'Acceptée': 'text-bg-success',
    'En préparation': 'text-bg-primary',
    'En cours de livraison': 'text-bg-info',
    'Livrée': 'text-bg-success',
    'En attente du retour de matériel': 'text-bg-warning',
    'Terminée': 'text-bg-dark',
    'Annulée': 'text-bg-danger'
} %}

	<div class="container py-5">

		<div class="d-flex justify-content-between align-items-center mb-4">
			<div>
				<h1 class="mb-1">
					Détail de la commande n°{{ order.id }}
				</h1>

				<p class="text-muted mb-0">
					Consultation et gestion de la commande client.
				</p>
			</div>

			<a href="{{ path('app_employee_index') }}" class="btn btn-outline-secondary">
				← Retour aux commandes
			</a>
		</div>

		<div
			class="row g-4">

			{# Informations client #}
			<div class="col-lg-5">
				<div class="card h-100">
					<div class="card-header">
						<strong>Informations client</strong>
					</div>

					<div class="card-body">
						<dl class="row mb-0">
							<dt class="col-sm-4">Nom</dt>
							<dd class="col-sm-8">
								{{ order.user.nom }}
							</dd>

							<dt class="col-sm-4">Prénom</dt>
							<dd class="col-sm-8">
								{{ order.user.prenom }}
							</dd>

							<dt class="col-sm-4">E-mail</dt>
							<dd class="col-sm-8">
								{{ order.user.email }}
							</dd>

							<dt class="col-sm-4">Téléphone</dt>
							<dd class="col-sm-8">
								{{ order.user.telephone ?? 'Non renseigné' }}
							</dd>
						</dl>
					</div>
				</div>
			</div>

			{# Informations commande #}
			<div class="col-lg-7">
				<div class="card h-100">
					<div class="card-header">
						<strong>Informations de la commande</strong>
					</div>

					<div class="card-body">
						<dl class="row mb-0">
							<dt class="col-sm-5">Commande créée le</dt>
							<dd class="col-sm-7">
								{{ order.createAt|date('d/m/Y à H:i') }}
							</dd>

							<dt class="col-sm-5">Menu</dt>
							<dd class="col-sm-7">
								{{ order.menu.title }}
							</dd>

							<dt class="col-sm-5">Nombre de personnes</dt>
							<dd class="col-sm-7">
								{{ order.numberOfPeople }}
							</dd>

							<dt class="col-sm-5">Date de livraison</dt>
							<dd class="col-sm-7">
								{{ order.deliveryDate|date('d/m/Y à H:i') }}
							</dd>

							<dt class="col-sm-5">Adresse de livraison</dt>
							<dd class="col-sm-7">
								{{ order.deliveryAdresse }}
							</dd>

							<dt class="col-sm-5">Prix total</dt>
							<dd class="col-sm-7">
								<strong>
									{{ order.totalPrice|number_format(2, ',', ' ') }}
									€
								</strong>
							</dd>

							<dt class="col-sm-5">Statut actuel</dt>
							<dd class="col-sm-7">
								<span class="badge {{ statusClasses[order.status] ?? 'text-bg-secondary' }}">
									{{ order.status }}
								</span>
							</dd>
						</dl>
					</div>
				</div>
			</div>

		</div>
        <div class="card mt-4">
    <div class="card-header">
        <strong>Gestion du statut</strong>
    </div>

    <div class="card-body">
        <form
            method="post"
            action="{{ path('app_employee_order_status', {
                id: order.id
            }) }}"
        >
            <div class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label
                        for="order-status"
                        class="form-label"
                    >
                        Nouveau statut
                    </label>

                    <select
                        id="order-status"
                        name="status"
                        class="form-select"
                        required
                    >
                        {% set statuses = [
                            'En attente',
                            'Acceptée',
                            'En préparation',
                            'En cours de livraison',
                            'Livrée',
                            'En attente du retour de matériel',
                            'Terminée',
                            'Annulée'
                        ] %}

                        {% for status in statuses %}
                            <option
                                value="{{ status }}"
                                {% if order.status == status %}
                                    selected
                                {% endif %}
                            >
                                {{ status }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-md-4 d-grid">
                    <button
                        type="submit"
                        class="btn btn-primary"
                    >
                        Enregistrer le statut
                    </button>
                </div>
            </div>

            <input
                type="hidden"
                name="_token"
                value="{{ csrf_token(
                    'update-status-' ~ order.id
                ) }}"
            >
        </form>
    </div>
</div>
	</div>
{% endblock %}
