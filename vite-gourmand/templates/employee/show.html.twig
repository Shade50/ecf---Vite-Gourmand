{% extends 'base.html.twig' %}

{% block title %}
	Commande n°{{ order.id }}
{% endblock %}

{% block body %}

	{% set statusClasses = {
    'En attente': 'text-bg-warning',
    'Acceptée': 'text-bg-success',
    'En préparation': 'text-bg-primary',
    'En cours de livraison': 'text-bg-info',
    'Livrée': 'text-bg-success',
    'En attente du retour de matériel': 'text-bg-warning',
    'Terminée': 'text-bg-dark',
    'Annulée': 'text-bg-danger'
} %}

	<div class="container py-5">

		<div class="d-flex justify-content-between align-items-center mb-4">
			<div>
				<h1 class="mb-1">
					Détail de la commande n°{{ order.id }}
				</h1>

				<p class="text-muted mb-0">
					Consultation et gestion de la commande client.
				</p>
			</div>

			<a href="{{ path('app_employee_index') }}" class="btn btn-outline-secondary">
				← Retour aux commandes
			</a>
		</div>

		<div
			class="row g-4">

			{# Informations client #}
			<div class="col-lg-5">
				<div class="card h-100">
					<div class="card-header">
						<strong>Informations client</strong>
					</div>

					<div class="card-body">
						<dl class="row mb-0">
							<dt class="col-sm-4">Nom</dt>
							<dd class="col-sm-8">
								{{ order.user.nom }}
							</dd>

							<dt class="col-sm-4">Prénom</dt>
							<dd class="col-sm-8">
								{{ order.user.prenom }}
							</dd>

							<dt class="col-sm-4">E-mail</dt>
							<dd class="col-sm-8">
								{{ order.user.email }}
							</dd>

							<dt class="col-sm-4">Téléphone</dt>
							<dd class="col-sm-8">
								{{ order.user.telephone ?? 'Non renseigné' }}
							</dd>
						</dl>
					</div>
				</div>
			</div>

			{# Informations commande #}
			<div class="col-lg-7">
				<div class="card h-100">
					<div class="card-header">
						<strong>Informations de la commande</strong>
					</div>

					<div class="card-body">
						<dl class="row mb-0">
							<dt class="col-sm-5">Commande créée le</dt>
							<dd class="col-sm-7">
								{{ order.createAt|date('d/m/Y à H:i') }}
							</dd>

							<dt class="col-sm-5">Menu</dt>
							<dd class="col-sm-7">
								{{ order.menu.title }}
							</dd>

							<dt class="col-sm-5">Nombre de personnes</dt>
							<dd class="col-sm-7">
								{{ order.numberOfPeople }}
							</dd>

							<dt class="col-sm-5">Date de livraison</dt>
							<dd class="col-sm-7">
								{{ order.deliveryDate|date('d/m/Y à H:i') }}
							</dd>

							<dt class="col-sm-5">Adresse de livraison</dt>
							<dd class="col-sm-7">
								{{ order.deliveryAdresse }}
							</dd>

							<dt class="col-sm-5">Prix total</dt>
							<dd class="col-sm-7">
								<strong>
									{{ order.totalPrice|number_format(2, ',', ' ') }}
									€
								</strong>
							</dd>

							<dt class="col-sm-5">Statut actuel</dt>
							<dd class="col-sm-7">
								<span class="badge {{ statusClasses[order.status] ?? 'text-bg-secondary' }}">
									{{ order.status }}
								</span>
							</dd>
						</dl>
					</div>
				</div>
			</div>

		</div>

		{# gestion du status de la commande #}
		<div class="card mt-4">
			<div class="card-header">
				<strong>Gestion du statut</strong>
			</div>

			<div class="card-body">
				<form method="post" action="{{ path('app_employee_order_status', { id: order.id }) }}">
					<div class="row g-3 align-items-end">
						<div class="col-md-8">
							<label for="order-status" class="form-label">
								Nouveau statut
							</label>

							<select id="order-status" name="status" class="form-select" required>
								{% set statuses = [
                            'En attente',
                            'Acceptée',
                            'En préparation',
                            'En cours de livraison',
                            'Livrée',
                            'En attente du retour de matériel',
                            'Terminée',
                            'Annulée'
                        ] %}

								{% for status in statuses %}
									<option value="{{ status }}" {% if order.status == status %} selected {% endif %}>
										{{ status }}
									</option>
								{% endfor %}
							</select>
						</div>

						<div class="col-md-4 d-grid">
							<button type="submit" class="btn btn-primary">
								Enregistrer le statut
							</button>
						</div>
					</div>

					<input type="hidden" name="_token" value="{{ csrf_token( 'update-status-' ~ order.id ) }}">
				</form>
			</div>
		</div>


		{# card modification/annulation commande #}

		{% if order.status == 'En attente' %}

			{# Carte Modification de la commande #}
			<div class="card mt-4">
				<div class="card-header">
					<strong>Modification / Annulation de la commande</strong>
				</div>

				<div class="card-body">

					<div class="row g-3 h-auto">

						<div class="col-md-6">
							<label class="form-label">Date de livraison</label>

							<input type="datetime-local" class="form-control" name="deliveryDate" value="{{ order.deliveryDate|date('Y-m-d\\TH:i') }}">
						</div>

						<div class="col-md-6">
							<label class="form-label">Nombre de personnes</label>

							<input type="number" class="form-control" name="numberOfPeople" value="{{ order.numberOfPeople }}">
						</div>

						<div class="col-12">
							<label class="form-label">Adresse de livraison</label>

							<textarea class="form-control" name="deliveryAdresse" rows="3">{{ order.deliveryAdresse }}</textarea>
						</div>

						<h3>Communication avec le client</h3>
						<p>---------------------------------</p>

						<div class="row g-3">
							<div class="col-md-6">
								<label class="form-label">
									Mode de contact
								</label>

								<div class="d-flex gap-4">
									<div class="form-check">
										<input class="form-check-input" type="radio" name="contactMode" id="contact-phone" value="Téléphone" required>

										<label class="form-check-label" for="contact-phone">
											Téléphone
										</label>
									</div>

									<div class="form-check">
										<input class="form-check-input" type="radio" name="contactMode" id="contact-email" value="E-mail" required>

										<label class="form-check-label" for="contact-email">
											E-mail
										</label>
									</div>
								</div>
							</div>

							<div class="col-12">
								<label for="contact-reason" class="form-label">
									Motif
								</label>

								<textarea id="contact-reason" name="contactReason" class="form-control" rows="3" required></textarea>
							</div>

							<div class="col-md-6 d-grid">
								<button type="submit" name="action" value="update" class="btn btn-primary">
									Enregistrer les modifications
								</button>
							</div>

							<div class="col-md-6 d-grid">
								<button type="submit" name="action" value="cancel" class="btn btn-danger" onclick="return confirm(
																																										                'Confirmer l’annulation de cette commande ?'
																																										            );">
									Annuler la commande
								</button>
							</div>
						</div>

					</div>

				</div>
			</div>
		</div>

	{% endif %}

{% endblock %}
