{% extends 'base.html.twig' %}

{% block title %}Paramètres du site
{% endblock %}

{% block body %}
	<div class="container py-5 text-center">
		<h1>Paramètres du site</h1>
		<p>Modifiez les informations affichées de votre site.</p>
	</div>
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-md-6 card mb-5">
				<form class="m-2" method="post" action="{{ path('app_admin_settings') }}">
					<p class="text-center text-muted small mb-4">Les champs marque de "<strong> * </strong>" son obligatoire</p>
                    <div class="mb-3">
						<label for="siteName" class="form-label">Nom du site <span class="text-danger">*</span></label>
						<input type="text" class="form-control" id="siteName" name="siteName" value="{{settings.siteName}}" required>
					</div>
					<div class="mb-3">
						<label for="email" class="form-label">Email de contact <span class="text-danger">*</span></label>
						<input type="email" class="form-control" id="siteEmail" name="siteEmail" value="{{settings.Email}}" required>
					</div>
					<div class="mb-3">
						<label for="sitePhone" class="form-label">votre Téléphone <span class="text-danger">*</span></label>
						<input type"tel" class="form-control" id="sitePhone" name="sitePhone" value="{{settings.Phone}}" required>
					</div>
					<div class="mb-3">
						<label for="siteAddress" class="form-label">Numero et nom de Rue <span class="text-danger">*</span></label>
						<input type"text" class="form-control" id="siteAddress" name="siteAddress" value="{{settings.Address}}" required>
					</div>
					<div class="mb-3">
						<label for="sitePostalCode" class="form-label">Code postal <span class="text-danger">*</span></label>
						<input type"text" class="form-control" id="sitePostalCode" name="sitePostalCode" value="{{settings.PostalCode}}" required>
					</div>
					<div class="mb-3">
						<label for="siteCity" class="form-label">Ville <span class="text-danger">*</span></label>
						<input type"text" class="form-control" id="siteCity" name="siteCity" value="{{settings.City}}" required>
					</div>
					<div class="mb-3">
						<label for="siteHoursWeekDays" class="form-label">Vos horaires du lundi au vendredi <span class="text-danger">*</span></label>
						<input type"text" class="form-control" id="siteHoursWeekDays" name="siteHoursWeekDays" value="{{settings.OpeningHoursWeekdays}}" required>
					</div>
					<div class="mb-3">
						<label for="siteHoursSaturday" class="form-label">Vos horaires du samedi <span class="text-danger">*</span></label>
						<input type"text" class="form-control" id="siteHoursSaturday" name="siteHoursSaturday" value="{{settings.OpeningHoursSaturday}}"required>
					</div>
					<div class="mb-3">
						<label for="siteHoursSunday" class="form-label">Vos horaires du dimanche <span class="text-danger">*</span></label>
						<input type"text" class="form-control" id="siteHoursSunday" name="siteHoursSunday" value="{{settings.OpeningHoursSunday}}" required>
					</div>
                    <div class="d-flex justify-content-center">
					    <button type="submit" class="btn btn_admin_setting"><i class="bi bi-floppy me-2"></i>Enregistrer</button>
                        <a href="{{path('app_admin')}}" class="btn btn_admin_setting">Retour</a>
                    </div>
				</div>
			</div>
		</div>
	{% endblock %}
